# Server
PORT=3000

# Database (Postgres)
DB_HOST=db
DB_PORT=5432
DB_NAME=e4e_roster
DB_USER=e4e
DB_PASSWORD=change-me
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# Authentik OIDC
# OIDC_ISSUER_URL is the provider discovery endpoint for your Authentik application
# Found in Authentik under: Applications > <your app> > OpenID Configuration URL
OIDC_ISSUER_URL=https://auth.example.com/application/o/e4e-roster/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Authentik group name that grants org_admin role in the E4E org on login
ADMIN_GROUP=your-admin-group-name
# Authentik group that grants system-wide admin access (across all orgs)
SYSTEM_ADMIN_GROUP=system-admin

# ── Encryption (for per-org integration secrets stored in DB) ─────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex-string

# ── Break-glass local admin (non-SSO, for initial setup only) ─────────
# Set these to create a local admin account on startup.
# Once a real system admin has logged in via SSO, delete this account
# through /system/local-admins and remove these vars from your environment.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Univention LDAP (username generation + read-only lookups) ─────
# Uses ldaps:// with rejectUnauthorized:false — matches how Authentik connects to this server
LDAP_URL=ldaps://your-univention-host
LDAP_BIND_DN=svc_roster@your-domain.intranet
LDAP_BIND_PASSWORD=your-service-account-password
LDAP_BASE_DN=dc=example,dc=com
LDAP_USERS_DN=cn=users,dc=example,dc=com
LDAP_GROUPS_DN=cn=groups,dc=example,dc=com

# ── Univention UDM REST API (user/group provisioning) ─────────────
# Expose via nginx reverse proxy with HTTPS — do NOT open the UDM port directly
# UDM_URL: base URL to the UDM REST API (no trailing slash)
# UDM_USERS_POSITION: LDAP DN path where new users are created
#   e.g. cn=users,dc=your-domain,dc=intranet
UDM_URL=https://your-univention-host/univention/udm
UDM_ADMIN_USER=Administrator
UDM_ADMIN_PASSWORD=your-udm-admin-password
UDM_USERS_POSITION=cn=users,dc=your-domain,dc=intranet
# DN of the primary group assigned to new users (usually Domain Users)
UDM_PRIMARY_GROUP=cn=Domain Users,cn=groups,dc=your-domain,dc=intranet

# ── GitHub App ────────────────────────────────────────────────────
# Register at: https://github.com/organizations/<org>/settings/apps/new
# Required permissions: Organization members (read/write), Webhooks
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=UCSD-E4E
GITHUB_APP_PORT=3001
