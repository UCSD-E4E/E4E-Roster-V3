{% extends "layout.njk" %}
{% block title %}Select Organization — Roster{% endblock %}
{% block body %}
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Roster</h1>
      <p>Select an organization to continue.</p>
    </div>

    <div style="display:flex;flex-direction:column;gap:.75rem;margin-top:1rem">
      {% for org in orgs %}
      <a href="/orgs/{{ org.orgSlug }}/dashboard" class="btn btn-secondary btn-full"
         style="text-align:left;display:flex;justify-content:space-between;align-items:center;
                {% if org.theme_color %}border-left:4px solid {{ org.theme_color }};{% endif %}">
        <span>{{ org.orgName }}</span>
        <span style="font-size:.8rem;opacity:.7">{{ org.role | replace('_', ' ') }}</span>
      </a>
      {% endfor %}

      {% if user.isSystemAdmin %}
      <hr style="margin:.5rem 0;border:none;border-top:1px solid var(--border)">
      <a href="/system" class="btn btn-ghost btn-full">System Admin</a>
      {% endif %}
    </div>

    <form method="POST" action="/logout" style="margin-top:1.5rem;text-align:center">
      <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
    </form>
  </div>
</div>
{% endblock %}
