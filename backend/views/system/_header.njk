<header class="app-header">
  <div class="app-header-inner">
    <a href="/orgs" class="app-brand">Roster System</a>
    <nav class="app-nav">
      <a href="/system/users">Users</a>
      <a href="/system/groups/new">New Group</a>
      <a href="/system/orgs">Organizations</a>
      <a href="/system/local-admins">Local Admins</a>
      <a href="/system/audit">Audit Log</a>
      {% if user.orgs and user.orgs.length %}
        <a href="/orgs">My Orgs</a>
      {% endif %}
      <span class="nav-user">{{ user.name or user.username }}</span>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
      </form>
    </nav>
  </div>
</header>
