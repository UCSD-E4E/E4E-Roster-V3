{% extends "layout.njk" %}
{% from "_macros.njk" import back_link %}
{% block title %}LDAP Mappings — {{ org.name }} — System{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "system/_header.njk" %}
  <main class="app-main">

    <div class="page-header">
      <div style="display:flex;align-items:flex-start;gap:1rem">
        {% if org.theme_color %}
        <div style="width:4px;border-radius:2px;background:{{ org.theme_color }};align-self:stretch;flex-shrink:0;margin-top:.25rem"></div>
        {% endif %}
        <div>
          {{ back_link('/system/orgs', 'Organizations') }}
          <h2 style="margin:.25rem 0 0;display:flex;align-items:center;gap:.6rem">
            {% if org.theme_color %}
            <span style="display:inline-block;width:.75rem;height:.75rem;border-radius:50%;background:{{ org.theme_color }};flex-shrink:0"></span>
            {% endif %}
            LDAP Mappings — {{ org.name }}
          </h2>
          <p class="text-muted" style="margin:0;font-size:.9rem">
            Define which LDAP groups grant which role in <strong>{{ org.name }}</strong>.
            Users in multiple groups get the highest-priority role.
          </p>
        </div>
      </div>
      <form method="POST" action="/system/orgs/{{ org.id }}/ldap-mappings/sync">
        <button class="btn btn-secondary" type="submit">Sync Members</button>
      </form>
    </div>

    {% if synced %}
    <div class="alert alert-success" style="margin-bottom:1rem">
      Sync complete — {{ synced }} user{{ 's' if synced != '1' }} added or updated in {{ org.name }}.
    </div>
    {% endif %}

    {% if error %}
    <div class="alert alert-error" style="margin-bottom:1rem">{{ error }}</div>
    {% endif %}

    <div class="layout-split">

      {# Left: current mappings #}
      <div>
        {% if mappings.length %}
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>LDAP Group</th>
                <th>Role</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {% for m in mappings %}
              <tr>
                <td><code>{{ m.ldap_group }}</code></td>
                <td>
                  <form method="POST" action="/system/orgs/{{ org.id }}/ldap-mappings/{{ m.id }}/role" style="margin:0">
                    <select name="role" class="form-input" style="padding:.2rem .4rem;font-size:.85rem;width:auto"
                            onchange="this.form.submit()">
                      <option value="member"       {{ 'selected' if m.role == 'member' }}>Member</option>
                      <option value="project_lead" {{ 'selected' if m.role == 'project_lead' }}>Project Lead</option>
                      <option value="org_admin"    {{ 'selected' if m.role == 'org_admin' }}>Org Admin</option>
                      <option value="utility"      {{ 'selected' if m.role == 'utility' }}>Utility</option>
                    </select>
                  </form>
                </td>
                <td>
                  <form method="POST" action="/system/orgs/{{ org.id }}/ldap-mappings/{{ m.id }}/delete" style="margin:0">
                    <button class="btn btn-ghost btn-sm" style="color:var(--danger)">Remove</button>
                  </form>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="text-muted">No LDAP mappings yet. Users won't have automatic org membership until at least one mapping is defined.</p>
        {% endif %}
      </div>

      {# Right: add mapping #}
      <div class="card">
        <h4>Add LDAP Mapping</h4>

        <form method="POST" action="/system/orgs/{{ org.id }}/ldap-mappings">
          <div style="margin-bottom:1rem">
            <label class="form-label">LDAP Group</label>
            {% if availableGroups.length %}
            <div class="checkbox-grid" style="max-height:240px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius);padding:.5rem">
              {% for g in availableGroups %}
              <label class="checkbox-label">
                <input type="radio" name="ldapGroup" value="{{ g }}" required> {{ g }}
              </label>
              {% endfor %}
            </div>
            <span class="form-hint">Already-mapped groups are hidden.</span>
            {% else %}
            <p class="form-hint">All available LDAP groups are already mapped, or LDAP is unreachable.</p>
            {% endif %}
          </div>
          <div style="margin-bottom:1rem">
            <label class="form-label">Role</label>
            <select name="role" class="form-input" required>
              <option value="member">Member</option>
              <option value="project_lead">Project Lead</option>
              <option value="org_admin">Org Admin</option>
              <option value="utility">Utility (no membership)</option>
            </select>
          </div>
          <button class="btn btn-primary" type="submit" {% if not availableGroups.length %}disabled{% endif %}>
            Add Mapping
          </button>
        </form>
      </div>

    </div>

  </main>
</div>
{% endblock %}
