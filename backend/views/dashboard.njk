{% extends "layout.njk" %}
{% block title %}Dashboard — {{ currentOrg.name if currentOrg else 'Roster' }}{% endblock %}

{% block body %}
<div class="app-layout">
  <header class="app-header">
    <div class="app-header-inner">
      <span class="app-brand">{{ currentOrg.name if currentOrg else 'Roster' }}</span>
      {% if user and user.orgs and user.orgs.length > 1 %}
      <span class="org-switcher">
        <a href="/orgs" class="org-switcher-link">Switch org</a>
      </span>
      {% endif %}
      <nav class="app-nav">
        {% if currentOrgMembership and currentOrgMembership.role === 'org_admin' or user.isSystemAdmin %}
        <a href="{{ orgBase }}/admin/users">Admin</a>
        {% endif %}
        {% if currentOrgMembership and (currentOrgMembership.role === 'project_lead' or currentOrgMembership.role === 'org_admin') or user.isSystemAdmin %}
        <a href="{{ orgBase }}/pl/projects">Project Lead</a>
        {% endif %}
        {% if user and user.isSystemAdmin %}
        <a href="/system">System</a>
        {% endif %}
        <span class="nav-user">{{ user.name or user.username }}</span>
        <form method="POST" action="/logout" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
        </form>
      </nav>
    </div>
  </header>

  <main class="app-main">
    <h2>Welcome, {{ user.name or user.username }}</h2>
    <p class="text-muted">{{ user.email }}</p>

    <div class="card-grid">
      <div class="card">
        <h3>Account Status</h3>
        <p class="text-muted">View your account details and contact info.</p>
        <a href="{{ orgBase }}/account" class="btn btn-secondary">View Account</a>
      </div>

      {% if currentOrgMembership and (currentOrgMembership.role === 'org_admin' or currentOrgMembership.role === 'project_lead') or user.isSystemAdmin %}
      <div class="card">
        <h3>Projects</h3>
        <p class="text-muted">Manage members across your projects.</p>
        <a href="{{ orgBase }}/pl/projects" class="btn btn-secondary">My Projects</a>
      </div>
      {% endif %}

      {% if currentOrgMembership and currentOrgMembership.role === 'org_admin' or user.isSystemAdmin %}
      <div class="card">
        <h3>Admin</h3>
        <p class="text-muted">Manage roster, provision accounts, view audit log.</p>
        <a href="{{ orgBase }}/admin/users" class="btn btn-secondary">Open Admin</a>
      </div>
      {% endif %}
    </div>
  </main>
</div>
{% endblock %}
