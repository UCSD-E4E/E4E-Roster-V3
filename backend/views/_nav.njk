<header class="app-header">
  <div class="app-header-inner">

    <a href="/dashboard" class="app-brand">KRG Roster</a>

    <nav class="app-nav">
      {% if currentUser and currentUser.isAdmin %}
      <div class="nav-dropdown">
        <button class="nav-org-chip" type="button">Admin <span class="nav-caret">▾</span></button>
        <div class="nav-dropdown-menu">
          <a href="/admin/users">Users</a>
          <a href="/admin/projects">Projects</a>
          <a href="/admin/integrations">Integrations</a>
          {% if currentUser.isSystemAdmin %}
          <div class="nav-dropdown-divider"></div>
          <a href="/system/orgs">Organisations</a>
          <a href="/system/admin-groups">Admin Groups</a>
          {% endif %}
        </div>
      </div>
      {% endif %}
      {% if currentUser and currentUser.orgRoles and currentUser.orgRoles.length %}
      <div class="nav-dropdown">
        <button class="nav-org-chip" type="button">
          Orgs <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu nav-orgs-menu">
          {% for orgRole in currentUser.orgRoles %}
          {% if not loop.first %}<div class="nav-dropdown-divider"></div>{% endif %}
          <div class="nav-org-section">
            {% if orgRole.themeColor %}
            <span class="nav-org-dot" style="background:{{ orgRole.themeColor }}"></span>
            {% endif %}
            <span class="nav-org-name">{{ orgRole.orgName }}</span>
            <span class="nav-org-role">{{ orgRole.role }}</span>
          </div>
          <a href="/orgs/{{ orgRole.orgSlug }}">Projects</a>
          {% if orgRole.role === 'org_admin' or currentUser.isSystemAdmin %}
          <a href="/orgs/{{ orgRole.orgSlug }}/admin">Manage Org</a>
          <a href="/orgs/{{ orgRole.orgSlug }}/admin/members">Members</a>
          {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}

      <a href="/dashboard">Dashboard</a>
      <a href="/account" class="nav-user">{{ currentUser.name or currentUser.username }}</a>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn-ghost btn-sm">Sign out</button>
      </form>
    </nav>

  </div>
</header>
