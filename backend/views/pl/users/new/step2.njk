{% extends "layout.njk" %}
{% block title %}Add Member — GitHub &amp; Slack — {{ project.name }}{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "pl/_header.njk" %}
  <main class="app-main">

    <div class="wizard-header">
      <h2>Add Member to {{ project.name }} — {{ wizard.user.username }}</h2>
      <ol class="wizard-steps">
        <li class="done">1. SSO Account</li>
        <li class="active">2. GitHub &amp; Slack</li>
      </ol>
    </div>

    <div class="card" style="max-width:640px">
      <h3>GitHub &amp; Slack</h3>
      <p class="text-muted" style="margin-bottom:1.5rem">
        Optionally record the user's GitHub and Slack handles. These can be added later.
      </p>

      <form method="POST" action="/pl/projects/{{ project.id }}/users/new/github-slack">

        <div class="form-group">
          <label for="githubUsername">GitHub username</label>
          <input type="text" id="githubUsername" name="githubUsername"
                 placeholder="e.g. octocat" autocomplete="off">
        </div>

        <div class="form-group">
          <label for="slackUsername">Slack username</label>
          <input type="text" id="slackUsername" name="slackUsername"
                 placeholder="e.g. jsmith" autocomplete="off">
          <span class="form-hint">Display name or member ID.</span>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save &amp; Finish →</button>
          <a href="/pl/projects/{{ project.id }}/users" class="btn btn-ghost">Skip &amp; Done</a>
        </div>

      </form>
    </div>

  </main>
</div>
{% endblock %}
