{% extends "layout.njk" %}
{% from "_macros.njk" import wizard_header %}
{% block title %}Add Member — {{ project.name }}{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "pl/_header.njk" %}
  <main class="app-main">

    {{ wizard_header('Add Member to ' + project.name, [
      {label: '1. SSO Account', state: 'active'},
      {label: '2. GitHub & Slack', state: ''}
    ]) }}

    <div class="card card-narrow">
      <h3>Create SSO Account</h3>
      <p class="text-muted" style="margin-bottom:1.5rem">
        Creates the user in Univention LDAP. Authentik will sync the account automatically.
      </p>

      <form method="POST" action="{{ orgBase }}/pl/projects/{{ project.id }}/users/new/sso">

        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First name</label>
            <input type="text" id="firstName" name="firstName" required autocomplete="off">
          </div>
          <div class="form-group">
            <label for="lastName">Last name</label>
            <input type="text" id="lastName" name="lastName" required autocomplete="off">
          </div>
        </div>

        <div class="form-group">
          <label for="email">Institutional email</label>
          <input type="email" id="email" name="email" required autocomplete="off">
          <span class="form-hint">Used to generate the username.</span>
        </div>

        <div class="form-group">
          <label for="secondaryEmail">Long-term email <span class="text-muted">(optional — personal, persists after graduation)</span></label>
          <input type="email" id="secondaryEmail" name="secondaryEmail" autocomplete="off"
                 placeholder="personal@gmail.com">
        </div>

        <div class="form-group">
          <label for="phone">Phone number <span class="text-muted">(optional)</span></label>
          <input type="tel" id="phone" name="phone" autocomplete="off"
                 placeholder="+1 555 000 0000">
        </div>

        <div class="form-group">
          <label>Username <span class="text-muted">(auto-generated)</span></label>
          <div class="username-preview" id="usernamePreview">—</div>
          <span class="form-hint">Format: first initial . last name . 3-digit hash of email</span>
        </div>

        <div class="form-group">
          <label>Account expiry</label>
          <input type="hidden" name="expiryDate" id="expiryDate">
          <div class="username-preview" id="expiryPreview" style="font-size:.9rem"></div>
          <span class="form-hint">Fixed at 90 days from today. An admin can adjust this later.</span>
        </div>

        <div class="form-group">
          <label>LDAP Groups <span class="text-muted">({{ project.name }} only)</span></label>
          {% if groups.length %}
          <div class="checkbox-grid">
            {% for group in groups %}
            <label class="checkbox-label">
              <input type="checkbox" name="ldapGroups" value="{{ group }}" checked> {{ group }}
            </label>
            {% endfor %}
          </div>
          {% else %}
          <p class="form-hint">No groups configured for this project — ask an admin to set them up.</p>
          {% endif %}
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Create SSO Account →</button>
          <a href="{{ orgBase }}/pl/projects/{{ project.id }}/users" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </main>
</div>

<script>
  async function sha512digits(email) {
    const msgBuffer = new TextEncoder().encode(email);
    const hashBuffer = await crypto.subtle.digest('SHA-512', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    const digits = Number(BigInt('0x' + hashHex) % 999n);
    return digits.toString().padStart(3, '0');
  }

  async function updatePreview() {
    const first = document.getElementById('firstName').value.trim().replace(/[^a-zA-Z]/g, '');
    const last  = document.getElementById('lastName').value.trim().replace(/[^a-zA-Z]/g, '');
    const email = document.getElementById('email').value.trim().toLowerCase();
    const preview = document.getElementById('usernamePreview');
    if (!first || !last || !email.includes('@')) { preview.textContent = '—'; return; }
    const digits = await sha512digits(email);
    preview.textContent = `${first[0].toLowerCase()}.${last.toLowerCase()}.${digits}`;
  }

  ['firstName', 'lastName', 'email'].forEach(id => {
    document.getElementById(id).addEventListener('input', updatePreview);
  });

  const expiry = new Date();
  expiry.setDate(expiry.getDate() + 90);
  const expiryStr = expiry.toISOString().slice(0, 10);
  document.getElementById('expiryDate').value = expiryStr;
  document.getElementById('expiryPreview').textContent = expiryStr;
</script>
{% endblock %}
