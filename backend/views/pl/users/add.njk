{% extends "layout.njk" %}
{% block title %}Add Existing Member — {{ project.name }}{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "pl/_header.njk" %}
  <main class="app-main">

    <div class="page-header">
      <h2>Add Existing Member to {{ project.name }}</h2>
    </div>

    <div class="card" style="max-width:640px">

      {# Search form #}
      <form method="GET" action="/pl/projects/{{ project.id }}/users/add">
        <div class="form-group">
          <label for="q">Find by username or email</label>
          <div class="form-row" style="align-items:flex-end;gap:.5rem">
            <input type="text" id="q" name="q" value="{{ query }}" autocomplete="off"
                   placeholder="s.perry.543 or shperry@ucsd.edu" style="flex:1">
            <button type="submit" class="btn btn-secondary">Search</button>
          </div>
        </div>
      </form>

      {% if error %}
      <div class="alert alert-error" style="margin-top:1rem">{{ error }}</div>
      {% endif %}

      {# Result #}
      {% if query and not found and not error %}
      <p class="text-muted" style="margin-top:1rem">No user found for <strong>{{ query }}</strong>.</p>
      {% endif %}

      {% if found %}
      <hr style="margin:1.5rem 0">
      <h3>{{ found.first_name }} {{ found.last_name }} <code style="font-size:.85rem">{{ found.username }}</code></h3>
      <p class="text-muted" style="margin-bottom:1rem">{{ found.email }} &mdash; {{ found.role or 'no role' }}</p>

      <form method="POST" action="/pl/projects/{{ project.id }}/users/add">
        <input type="hidden" name="username" value="{{ found.username }}">

        <div class="form-group">
          <label>{{ project.name }} groups</label>
          {% if projGroups.length %}
          <div class="checkbox-grid">
            {% for group in projGroups %}
            <label class="checkbox-label">
              <input type="checkbox" name="groups" value="{{ group }}"
                {% if found.ldap_groups and group in found.ldap_groups %}checked{% endif %}>
              {{ group }}
            </label>
            {% endfor %}
          </div>
          {% else %}
          <p class="form-hint">No groups configured for this project.</p>
          {% endif %}
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add to Project</button>
          <a href="/pl/projects/{{ project.id }}/users" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
      {% endif %}

      {% if not query %}
      <div class="form-actions" style="margin-top:1.5rem">
        <a href="/pl/projects/{{ project.id }}/users/new" class="btn btn-ghost">Create a new user instead →</a>
      </div>
      {% endif %}

    </div>
  </main>
</div>
{% endblock %}
