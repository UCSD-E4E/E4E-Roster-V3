{% extends "layout.njk" %}
{% from "_macros.njk" import back_link, status_badge %}
{% block title %}{{ project.name }} Members{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "pl/_header.njk" %}
  <main class="app-main">

    <div class="page-header">
      <div>
        {{ back_link(orgBase + '/pl/projects', 'My Projects') }}
        <h2 style="margin:.25rem 0 0">{{ project.name }}</h2>
      </div>
      <a href="{{ orgBase }}/pl/projects/{{ project.id }}/users/add" class="btn btn-secondary">+ Add Existing</a>
      <a href="{{ orgBase }}/pl/projects/{{ project.id }}/users/new" class="btn btn-primary">+ New Member</a>
    </div>

    {% if warning %}
    <div class="alert alert-error" style="margin-top:1rem">{{ warning }}</div>
    {% endif %}

    {% if users.length %}
    <div class="table-wrapper" style="margin-top:1rem">
      <table class="data-table">
        <thead>
          <tr>
            <th>Username</th>
            <th>Name</th>
            <th>Email</th>
            <th>Expiry</th>
            <th>GitHub</th>
            <th>Slack</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for u in users %}
          <tr class="{{ 'row-disabled' if u.disabled }}">
            <td><code>{{ u.username }}</code></td>
            <td>{{ u.first_name }} {{ u.last_name }}</td>
            <td>{{ u.email }}</td>
            <td>{{ u.expiry_date or 'No expiry' }}</td>
            <td>{{ u.github_username or '—' }}</td>
            <td>{{ u.slack_username or '—' }}</td>
            <td>
              {{ status_badge(u.disabled) }}
            </td>
            <td style="display:flex;gap:.25rem">
              <a href="{{ orgBase }}/pl/projects/{{ project.id }}/users/{{ u.username }}/edit" class="btn btn-ghost btn-sm">Edit</a>
              <a href="{{ orgBase }}/pl/projects/{{ project.id }}/users/{{ u.username }}/audit" class="btn btn-ghost btn-sm">Log</a>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="text-muted" style="margin-top:1rem">No members in this project yet.</p>
    {% endif %}

  </main>
</div>
{% endblock %}
