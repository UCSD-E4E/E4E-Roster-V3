{% extends "layout.njk" %}
{% block title %}{{ org.name }}{% endblock %}
{% block body %}
<div class="section-strip" {% if org.theme_color %}style="border-top:3px solid {{ org.theme_color }}"{% endif %}>
  <div class="section-strip-inner">
    <span class="section-label">{{ org.name }}</span>
    <a href="/orgs/{{ org.slug }}" class="active">Projects</a>
    {% if currentUser.isSystemAdmin or (currentUser.orgRoles and currentUser.orgRoles | selectattr('orgSlug', 'equalto', org.slug) | selectattr('role', 'equalto', 'org_admin') | list | length) %}
    <a href="/orgs/{{ org.slug }}/admin">Admin</a>
    {% endif %}
  </div>
</div>
<main class="app-main">

    <div class="page-header">
      <h2>{{ org.name }} — Projects</h2>
    </div>

    {% if projects.length %}
    <div class="card-grid">
      {% for project in projects %}
      <div class="card">
        <h3>{{ project.name }}</h3>
        {% if project.description %}<p class="text-muted">{{ project.description }}</p>{% endif %}
        {% if project.id in manageableIds %}
        <div style="margin-top:auto;padding-top:.75rem">
          <a href="/orgs/{{ org.slug }}/projects/{{ project.id }}/manage" class="btn btn-primary btn-sm">Manage Members</a>
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="text-muted">No projects yet for this organisation.</p>
    {% endif %}

  </main>
{% endblock %}
