{% extends "layout.njk" %}
{% block title %}Add Existing Member — {{ org.name }}{% endblock %}
{% block body %}
<div class="app-layout">
  <header class="app-header" {% if org.theme_color %}style="border-bottom: 3px solid {{ org.theme_color }}"{% endif %}>
    <span class="app-header-logo">{{ org.name }}</span>
    <span class="text-muted" style="font-size:.85rem">Org Admin</span>
    <nav class="app-header-nav" style="margin-left:auto">
      <a href="/orgs/{{ org.slug }}/admin">Projects</a>
      <a href="/orgs/{{ org.slug }}/admin/members" class="active">Members</a>
      <a href="/orgs/{{ org.slug }}">← Org</a>
    </nav>
  </header>
  <main class="app-main">

    <div class="page-header">
      <a href="/orgs/{{ org.slug }}/admin/members" style="font-size:.85rem;color:var(--text-muted)">← Members</a>
      <h2 style="margin:.25rem 0 0">Add Existing User</h2>
    </div>

    <div class="card" style="max-width:640px">

      <form method="GET" action="/orgs/{{ org.slug }}/admin/members/add">
        <div class="form-group">
          <label for="q">Find by username or email</label>
          <div class="form-row" style="align-items:flex-end;gap:.5rem">
            <input type="text" id="q" name="q" value="{{ query }}" autocomplete="off"
                   placeholder="s.perry.543 or shperry@ucsd.edu" style="flex:1">
            <button type="submit" class="btn btn-secondary">Search</button>
          </div>
        </div>
      </form>

      {% if error %}
      <div class="alert alert-error" style="margin-top:1rem">{{ error }}</div>
      {% endif %}

      {% if query and not found and not error %}
      <p class="text-muted" style="margin-top:1rem">No user found for <strong>{{ query }}</strong>.</p>
      {% endif %}

      {% if found %}
      <hr style="margin:1.5rem 0">
      <h3>{{ found.first_name }} {{ found.last_name }} <code style="font-size:.85rem">{{ found.username }}</code></h3>
      <p class="text-muted" style="margin-bottom:1rem">{{ found.email }} &mdash; {{ found.role or 'no role' }}</p>

      <form method="POST" action="/orgs/{{ org.slug }}/admin/members/add">
        <input type="hidden" name="username" value="{{ found.username }}">

        <div class="form-group">
          <label>Assign to org groups</label>
          {% if orgGroups.length %}
          <div class="checkbox-grid">
            {% for group in orgGroups %}
            <label class="checkbox-label">
              <input type="checkbox" name="groups" value="{{ group }}"
                {% if found.ldap_groups and group in found.ldap_groups %}checked{% endif %}>
              {{ group }}
            </label>
            {% endfor %}
          </div>
          {% else %}
          <p class="form-hint">No groups configured for this org yet.</p>
          {% endif %}
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add to Org</button>
          <a href="/orgs/{{ org.slug }}/admin/members" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
      {% endif %}

      {% if not query %}
      <div class="form-actions" style="margin-top:1.5rem">
        <a href="/orgs/{{ org.slug }}/admin/members/new" class="btn btn-ghost">Create a new user instead →</a>
      </div>
      {% endif %}

    </div>
  </main>
</div>
{% endblock %}
