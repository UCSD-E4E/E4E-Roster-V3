{% extends "layout.njk" %}
{% from "_macros.njk" import wizard_header %}
{% block title %}New User — GitHub &amp; Slack{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "admin/_header.njk" %}
  <main class="app-main">

    {{ wizard_header('Add New User — ' + wizard.user.username, [
      {label: '1. SSO Account', state: 'done'},
      {label: '2. GitHub & Slack', state: 'active'},
      {label: '3. Server Access', state: ''}
    ]) }}

    <div class="card card-narrow">
      <h3>GitHub &amp; Slack</h3>
      <p class="text-muted" style="margin-bottom:1.5rem">
        Record the user's GitHub and Slack handles. Org invites can be sent later.
      </p>

      {% if error %}
      <div class="alert alert-error">{{ error }}</div>
      {% endif %}

      <form method="POST" action="{{ orgBase }}/admin/users/new/github-slack">

        <div class="form-group">
          <label for="githubUsername">GitHub username</label>
          <input type="text" id="githubUsername" name="githubUsername"
                 placeholder="e.g. octocat" autocomplete="off">
        </div>

        <div class="form-group">
          <label for="slackUsername">Slack username</label>
          <input type="text" id="slackUsername" name="slackUsername"
                 placeholder="e.g. jsmith" autocomplete="off">
          <span class="form-hint">Display name or member ID — whichever you use to identify them.</span>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save &amp; Continue →</button>
          <a href="{{ orgBase }}/admin/users/new/server" class="btn btn-secondary">Skip</a>
          <a href="{{ orgBase }}/admin/users" class="btn btn-ghost">Done for now</a>
        </div>

      </form>
    </div>

  </main>
</div>
{% endblock %}
