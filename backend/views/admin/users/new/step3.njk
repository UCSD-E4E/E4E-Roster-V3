{% extends "layout.njk" %}
{% block title %}New User — Server Access{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "admin/_header.njk" %}
  <main class="app-main">

    <div class="wizard-header">
      <h2>Add New User — {{ wizard.user.username }}</h2>
      <ol class="wizard-steps">
        <li class="done">1. SSO Account</li>
        <li class="done">2. GitHub &amp; Slack</li>
        <li class="active">3. Server Access</li>
      </ol>
    </div>

    <div class="card" style="max-width:640px">
      <h3>Server Access</h3>
      <p class="text-muted">
        Provisions accounts on lab servers via Ansible.
        <br><strong>Coming soon</strong> — not yet implemented.
      </p>
      <div class="form-actions" style="margin-top:1.5rem">
        <a href="/admin/users" class="btn btn-primary">Done — Back to Users</a>
      </div>
    </div>

  </main>
</div>
{% endblock %}
