{% extends "layout.njk" %}
{% block title %}Edit User — {{ user.username }}{% endblock %}
{% block body %}
<div class="app-layout">
  {% include "admin/_header.njk" %}
  <main class="app-main">

    <div class="page-header">
      <h2>Edit User</h2>
    </div>

    <div class="card" style="max-width:640px">
      <h3>{{ user.first_name }} {{ user.last_name }} <code style="font-size:.9rem">{{ user.username }}</code></h3>

      {% if error %}
      <div class="alert alert-error">{{ error }}</div>
      {% endif %}

      <form method="POST" action="/admin/users/{{ user.username }}/edit">

        <div class="form-group">
          <label for="role">Role</label>
          <select id="role" name="role">
            <option value="">— unset —</option>
            <option value="student"    {{ 'selected' if user.role == 'student' }}>Student</option>
            <option value="researcher" {{ 'selected' if user.role == 'researcher' }}>Researcher</option>
            <option value="staff"      {{ 'selected' if user.role == 'staff' }}>Staff</option>
            <option value="alumni"     {{ 'selected' if user.role == 'alumni' }}>Alumni</option>
          </select>
        </div>

        <div class="form-group">
          <label for="expiryDate">Account expiry</label>
          <input type="date" id="expiryDate" name="expiryDate"
                 value="{{ user.expiry_date or '' }}">
          <span class="form-hint">Leave blank for no expiry.</span>
        </div>

        <div class="form-group">
          <label>LDAP Groups</label>
          {% if allGroups.length %}
          <div class="checkbox-grid">
            {% for group in allGroups %}
            <label class="checkbox-label">
              <input type="checkbox" name="groups" value="{{ group }}"
                {% if user.ldap_groups and group in user.ldap_groups %}checked{% endif %}>
              {{ group }}
            </label>
            {% endfor %}
          </div>
          {% else %}
          <p class="form-hint">Could not fetch groups from UDM.</p>
          {% endif %}
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save</button>
          <a href="/admin/users" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>

  </main>
</div>
{% endblock %}
