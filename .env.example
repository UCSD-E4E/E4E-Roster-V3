# ── Server ────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# ── Authentik OIDC ────────────────────────────────────────────────
# OIDC_ISSUER_URL: provider discovery URL for your Authentik application.
# Found in Authentik under: Applications > <your app> > OpenID Configuration URL
OIDC_ISSUER_URL=https://auth.example.com/application/o/e4e-roster/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Must match one of the redirect URIs configured in your Authentik application
OIDC_REDIRECT_URI=https://roster.example.com/auth/callback

# Authentik group name that grants admin access (must match LDAP group in Authentik)
ADMIN_GROUP=e4e-staff

# ── Database ──────────────────────────────────────────────────────
DB_NAME=e4e_roster
DB_USER=e4e
DB_PASSWORD=change-me-to-a-strong-password
