# Server
PORT=3000

# Database (Postgres)
DB_HOST=db
DB_PORT=5432
DB_NAME=e4e_roster
DB_USER=e4e
DB_PASSWORD=change-me
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# Authentik OIDC
# OIDC_ISSUER_URL is the provider discovery endpoint for your Authentik application
# Found in Authentik under: Applications > <your app> > OpenID Configuration URL
OIDC_ISSUER_URL=https://auth.example.com/application/o/e4e-roster/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Authentik group name that grants admin access (must match LDAP group name in Authentik)
ADMIN_GROUP=your-admin-group-name

# ── Samba4 AD LDAP ────────────────────────────────────────────────
# Uses ldaps:// with rejectUnauthorized:false for self-signed certs
LDAP_URL=ldaps://your-samba4-host
LDAP_BIND_DN=CN=svc_roster,CN=Users,DC=your-domain,DC=intranet
LDAP_BIND_PASSWORD=your-service-account-password
LDAP_BASE_DN=DC=your-domain,DC=intranet
LDAP_USERS_DN=CN=Users,DC=your-domain,DC=intranet
LDAP_GROUPS_DN=CN=Users,DC=your-domain,DC=intranet
# Domain suffix used for userPrincipalName when creating accounts (e.g. your-domain.intranet)
LDAP_DOMAIN=your-domain.intranet

# ── GitHub App ────────────────────────────────────────────────────
# Register at: https://github.com/organizations/<org>/settings/apps/new
# Required permissions: Organization members (read/write), Webhooks
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=UCSD-E4E
GITHUB_APP_PORT=3001
