# ── Server ────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=production

# ── Authentik OIDC ────────────────────────────────────────────────
# OIDC_ISSUER_URL: provider discovery URL for your Authentik application.
# Found in Authentik under: Applications > <your app> > OpenID Configuration URL
OIDC_ISSUER_URL=https://auth.example.com/application/o/e4e-roster/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Must match one of the redirect URIs configured in your Authentik application
OIDC_REDIRECT_URI=https://roster.example.com/auth/callback

# Authentik group name that grants admin access (must match LDAP group in Authentik)
ADMIN_GROUP=e4e-staff

# ── UDM REST API (Univention — user provisioning) ─────────────────
UDM_URL=https://your-univention-host/univention/udm
UDM_ADMIN_USER=Administrator
UDM_ADMIN_PASSWORD=change-me
UDM_USERS_POSITION=cn=users,dc=example,dc=com

# ── Database ──────────────────────────────────────────────────────
DB_NAME=e4e_roster
DB_USER=e4e
DB_PASSWORD=change-me-to-a-strong-password

# ── GitHub App ────────────────────────────────────────────────────
# Register at: https://github.com/organizations/UCSD-E4E/settings/apps/new
# Required permissions: Organization members (read/write)
# After registering, install the app on the UCSD-E4E org and set the
# webhook URL to https://your-host/webhook
GITHUB_APP_ID=your-numeric-app-id
# Paste the downloaded PEM with literal \n between lines (no real newlines in .env)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=change-me-to-a-random-string
GITHUB_ORG=UCSD-E4E
GITHUB_APP_PORT=3001

# ── Slack Bot ─────────────────────────────────────────────────────
# Create a bot at: https://api.slack.com/apps
# Required scopes: users:read, users:read.email, channels:read
# SLACK_BOT_TOKEN is the Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# App-Level Token for socket mode — generate under Settings > Basic Information > App-Level Tokens
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-level-token
# Channel to post admin sync reports (e.g. #e4e-roster-admin or channel ID C01234567)
SLACK_ADMIN_REPORT_CHANNEL=#e4e-roster-admin
# Dev only: restrict outbound DMs to a single user email (comment out in production)
# DEV_SLACKUSER=your-email@ucsd.edu
